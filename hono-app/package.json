{
	"name": "hono-app",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"deploy:prod": "wrangler deploy --config ./config/wrangler.jsonc --minify --env production",
		"push-prod-env": "wrangler secret bulk .env.production --cwd ./config --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"hono": "^4.12.28"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"wrangler": "^4.110.0"
	}
}