{
	"name": "crud-app",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --config ./config/wrangler.jsonc",
		"deploy": "wrangler deploy --config ./config/wrangler.jsonc --minify --env production",
		"push-prod-env": "wrangler secret bulk .env --cwd ./config --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings --config ./config/wrangler.jsonc",
		"create-migration": "wrangler d1 migrations create user-db --config ./config/wrangler.jsonc",
    "apply-migration:dev": "wrangler d1 migrations apply user-db --local --config ./config/wrangler.jsonc",
    "apply-migration:prod": "wrangler d1 migrations apply user-db --remote --config ./config/wrangler.jsonc",
    "list-migrations:dev": "wrangler d1 migrations list user-db --local --config ./config/wrangler.jsonc",
    "list-migrations:prod": "wrangler d1 migrations list user-db --remote --config ./config/wrangler.jsonc"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.8.0",
		"hono": "^4.12.30",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"wrangler": "^4.110.0"
	}
}